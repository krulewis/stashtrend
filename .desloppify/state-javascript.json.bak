      "id": "review::.::holistic::error_consistency::mixed-error-surfacing-patterns::29a031b2",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "Error handling across pages and components uses inconsistent strategies for surfacing errors to users \u2014 some use state-driven error displays, others use console.warn fire-and-forget",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
