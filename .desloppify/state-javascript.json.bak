    "review::.::holistic::design_coherence::groupspage-multiple-responsibilities::4b797bf1": {
      "id": "review::.::holistic::design_coherence::groupspage-multiple-responsibilities::4b797bf1",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "GroupsPage combines data fetching, config management, conflict computation, and selection state into a single 191-line component with 8 state variables",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "frontend/src/pages/GroupsPage.jsx"
        ],
        "evidence": [
          "GroupsPage.jsx: 8 useState hooks, 1 useMemo for conflictMap, 1 useMemo for filteredSnapshot, 5 useCallback handlers",
          "Three distinct responsibilities: (1) data loading (groups, accounts, history, snapshot), (2) config CRUD (save, delete, rename, select), (3) selection state management (selectedGroupIds, conflictMap, filteredSnapshot)",
          "Compare with SyncPage.jsx (72 lines, 5 state variables) and BudgetPage.jsx (85 lines, 4 state variables)"
        ],
        "suggestion": "Extract config management into a useGroupConfigs() hook and consider extracting conflict/selection logic into useGroupSelection(). This would reduce GroupsPage to ~60 lines of composition, matching the complexity of sibling pages.",
        "reasoning": ""
      },
      "status": "wontfix",
      "note": "GroupsPage as page-level orchestrator and AccountSection's 9 params are both standard patterns in this codebase. The prop count reflects domain complexity, not design debt.",
