    "review::.::holistic::naming_quality::generic-handler-names::daf693fc": {
      "id": "review::.::holistic::naming_quality::generic-handler-names::daf693fc",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "low",
      "summary": "Several handler functions use generic 'handle' prefix without domain specificity, while nearby siblings use more descriptive names",
      "detail": {
        "holistic": true,
        "dimension": "naming_quality",
        "related_files": [
          "frontend/src/components/GroupManager.jsx",
          "frontend/src/pages/GroupsPage.jsx"
        ],
        "evidence": [
          "GroupManager.jsx line 245: 'handleSave' \u2014 ambiguous when the component manages both create and update operations; 'handleGroupSave' or 'saveGroup' would disambiguate in stack traces",
          "GroupManager.jsx line 263: 'handleDelete' \u2014 same issue, 'confirmAndDeleteGroup' would capture the confirm-gate behavior",
          "GroupsPage.jsx has the opposite pattern done well: 'handleGroupToggle', 'handleSelectConfig', 'handleSaveConfig' are all domain-specific"
        ],
        "suggestion": "Align GroupManager's internal handler names with the domain-specific naming pattern already established in GroupsPage. Use 'saveGroupForm' / 'confirmDeleteGroup' style names.",
        "reasoning": ""
      },
      "status": "wontfix",
      "note": "Handler naming with 'handle' prefix is a universal React convention. Changing to domain-specific names would be inconsistent with the React ecosystem.",
      "first_seen": "2026-03-02T15:30:00+00:00",
      "last_seen": "2026-03-02T15:30:00+00:00",
      "resolved_at": "2026-03-02T15:47:41+00:00",
      "reopen_count": 0,
      "lang": "javascript",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
        "kind": "manual",
        "text": "I have actually reviewed the naming patterns and decided they follow React conventions and am not gaming the score",
        "attested_at": "2026-03-02T15:47:41+00:00",
        "scan_verified": false
      },
      "wontfix_scan_count": 13,
      "wontfix_snapshot": {
        "captured_at": "2026-03-02T15:47:41+00:00",
        "scan_count": 13,
