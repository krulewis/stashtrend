    "review::.::holistic::test_strategy::mockfetch_route_ambiguity::27d39e81": {
      "id": "review::.::holistic::test_strategy::mockfetch_route_ambiguity::27d39e81",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "mockFetch substring matching can silently match wrong routes when URL prefixes overlap",
      "detail": {
        "holistic": true,
        "dimension": "test_strategy",
        "related_files": [
          "frontend/src/test/fixtures.js"
        ],
        "evidence": [
          "mockFetch uses url.includes(key) \u2014 '/api/budget-builder/regional' matches both the GET endpoint and '/api/budget-builder/regional/fetch'",
          "Tests that need both routes (e.g. BudgetBuilderPage handleFetchRegionalAI) work around this by replacing global.fetch entirely with vi.fn() instead of using mockFetch",
          "Route match order depends on Object.entries iteration order, creating implicit ordering dependencies"
        ],
        "suggestion": "Sort routes by descending key length in mockFetch so longer/more-specific routes match first, or switch to exact path matching with optional query string handling",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-03T15:51:39+00:00",
