    "review::.::holistic::type_safety::no_prop_validation_anywhere::24835006": {
      "id": "review::.::holistic::type_safety::no_prop_validation_anywhere::24835006",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Zero PropTypes or TypeScript across all 15 production components \u2014 runtime type errors are undetectable",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "frontend/src/components/GroupsSnapshot.jsx",
          "frontend/src/components/GroupSnapshotControls.jsx",
          "frontend/src/components/SyncControl.jsx",
          "frontend/src/components/AccountsBreakdown.jsx",
          "frontend/src/pages/GroupsPage.jsx"
        ],
        "evidence": [
          "GroupsSnapshot accepts 11 props (snapshot, groups, selectedGroupIds, configs, activeConfigId, conflictMap, onGroupToggle, onSelectConfig, onSaveConfig, onDeleteConfig, onRenameConfig) with no type validation. GroupSnapshotControls accepts 9 props. AccountSection accepts 9 props. None of these have PropTypes, TypeScript, or JSDoc @param annotations.",
          "selectedGroupIds is documented in a comment as 'Set<id> | null' in GroupSnapshotControls (line 12) but the actual runtime contract from GroupsPage always passes a Set (never null). This silent divergence between doc and code would be caught by types.",
          "SyncJobStatus.jsx line 110 calls row.recordCount.toLocaleString() which will throw if recordCount is undefined rather than null \u2014 there is a null check on line 108 but no undefined guard."
        ],
        "suggestion": "Add PropTypes to the top-level components with wide prop interfaces (GroupsSnapshot, GroupSnapshotControls, SyncControl, AccountSection, GroupForm). Alternatively, migrate to TypeScript. The most impactful starting point is components with >5 props where a caller could easily pass the wrong shape.",
        "reasoning": ""
      },
      "status": "fixed",
      "note": null,
      "first_seen": "2026-03-02T15:05:35+00:00",
      "last_seen": "2026-03-02T15:05:35+00:00",
